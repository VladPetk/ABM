# Phase 9 cluster-diversity investigation variant dumps + logs.
phase9_div_*.json
phase9_logs/

# Local research artifacts — kept on workstation, not in repo.
# Diagnostic dumps from sweep scripts land here.
local_artifacts/

# Phase 9 Tier-A sweep noise — keep blessed/baseline/sweep CSV,
