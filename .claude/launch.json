{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "solara",
      "runtimeExecutable": ".venv\\Scripts\\solara.exe",
      "runtimeArgs": ["run", "abm.viz.solara_app", "--host", "127.0.0.1", "--port", "8765"],
      "port": 8765
    },
    {
      "name": "web",
      "runtimeExecutable": ".venv\\Scripts\\python.exe",
      "runtimeArgs": ["-m", "uvicorn", "abm.web.server:app", "--host", "127.0.0.1", "--port", "8000"],
      "port": 8000
    }
  ]
}
